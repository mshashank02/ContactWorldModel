<?xml version='1.0' encoding='utf-8'?>
<mujoco>
    <compiler angle="radian" coordinate="local" meshdir="../stls/hand" texturedir="../textures" />
    <option timestep="0.001" integrator="implicitfast" solver="CG" tolerance="1e-6" iterations="50" apirate="200">
        <flag warmstart="enable" />
    </option>
    


    <include file="shared.xml" />
    <include file="shared_touch_sensors_16_0.4_0.3.xml" /> 

    <asset>
        <include file="shared_asset.xml" />

        <texture name="texture:object" file="block.png" gridsize="3 4" gridlayout=".U..LFRB.D.." />
        <texture name="texture:hidden" file="block_hidden.png" gridsize="3 4" gridlayout=".U..LFRB.D.." />

        <material name="material:object" texture="texture:object" specular="1" shininess="0.3" reflectance="0" />
        <material name="material:hidden" texture="texture:hidden" specular="1" shininess="0.3" reflectance="0" />
        <material name="material:target" texture="texture:object" specular="1" shininess="0.3" reflectance="0" rgba="1 1 1 0.5" />
    </asset>

    <worldbody>
        <geom name="floor0" pos="1 1 0" size="1 1 1" type="plane" condim="3" material="floor_mat" />
        <body name="floor0" pos="1 1 0" />

        <include file="Sensors_withPos_16_0.4_0.3.xml" /> 

        <body name="object" pos="1 0.87 0.4">
            <!-- Keep the free joint so the object can move in the hand task -->
            <joint name="object:joint" type="free" damping="0.05" />
            <inertial pos="0 0 0" mass="0.5" diaginertia="1e-3 1e-3 1e-3"/>
            <!-- Deformable object -->
            <flexcomp name="soft" type="gmsh"
                        file="/home/mshashank02/SoftObjectsV2/objects_sphere/sphere_macro_high_rough_high.obj_.msh"
                        dim="3" dof="trilinear"
                        pos="0 0 0" scale="0.025 0.025 0.025"
                        radius="0.001" rigid="true"
                        rgba="0.7 0.8 1.0 0.5">
                <contact selfcollide="none" internal="false"/>
            </flexcomp>

            <!-- Keep a site for task observations / reward code that expects it -->
            <site name="object:center" pos="0 0 0" rgba="1 0 0 1" size="0.001 0.001 0.001" />
            <!-- axis endpoints -->
            <site name="obj:x" pos="0.03 0 0" size="0.004" rgba="1 0 0 1"/>
            <site name="obj:y" pos="0 0.03 0" size="0.004" rgba="0 1 0 1"/>
            <site name="obj:z" pos="0 0 0.03" size="0.004" rgba="0 0 1 1"/>

            <!-- axis lines -->
            <geom name="obj:x_axis" type="capsule" fromto="0 0 0 0.03 0 0" size="0.0015"
                rgba="1 0 0 1" contype="0" conaffinity="0" group="3"/>
            <geom name="obj:y_axis" type="capsule" fromto="0 0 0 0 0.03 0" size="0.0015"
                rgba="0 1 0 1" contype="0" conaffinity="0" group="3"/>
            <geom name="obj:z_axis" type="capsule" fromto="0 0 0 0 0 0.03" size="0.0015"
                rgba="0 0 1 1" contype="0" conaffinity="0" group="3"/>

        </body>

        <light directional="true" ambient="0.2 0.2 0.2" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" castshadow="false" pos="0 1 4" dir="0 0 -1" name="light0" />
    </worldbody>
</mujoco>